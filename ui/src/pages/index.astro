---
import GlobalMay19Corner from "../components/GlobalMay19Corner.astro";

const GITHUB_REPO_URL = "https://github.com/candasoz01-cmd/lumos-core";
---

<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Lumos by We Lock AI</title>
    <meta
      name="description"
      content="We Lock AI çatısı altındaki Lumos: tek panelde çoklu akışı bir araya getiren, kararı kullanıcıda tutan yapay zekâ kontrol ve asistan katmanı."
    />
    <link rel="canonical" href="https://welockai.com/" />
    <meta property="og:title" content="Lumos by We Lock AI" />
    <meta
      property="og:description"
      content="Lumos, We Lock AI çatısı altında geliştirilen insan merkezli yapay zekâ kontrol katmanıdır."
    />
    <meta property="og:url" content="https://welockai.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:image" content="https://welockai.com/lumos-world-map.jpg" />
    <meta property="og:image:type" content="image/jpeg" />
    <link rel="icon" href="/lumos-tree-logo.svg" type="image/svg+xml" sizes="any" />
    <link rel="apple-touch-icon" href="/lumos-tree-logo.svg" />
    <style>
      /**
       * Landing: Lumos-son hero havası — çok koyu lacivert/siyah zemin, elektrik cyan-mavi,
       * kontrollü sıcak altın ikincil. `--lumos-land-teal` adı panel uyumu için; değerler cyan-mavi kanalı.
       */
      :root {
        --lumos-land-teal: 56 206 255;
        --lumos-land-teal-deep: 8 52 108;
        --lumos-land-warm: 186 148 88;
        --lumos-land-warm-deep: 128 96 54;
        /** Harita / hero ile aynı zemin */
        --lumos-map-canvas: #020511;
        --lumos-land-page: #030714;
        --lumos-land-title: #e9eef5;
        --lumos-text-muted: #d7e7f2;
        --lumos-text-body: #d4dae8;
        --lumos-text-sep: rgb(138 152 172 / 0.42);
        --lumos-heading-warm: #d6ccb8;
        --lumos-interactive-fg: rgb(var(--lumos-land-teal) / 0.92);
        --lumos-interactive-fg-hover: #b8f0ff;

        --lumos-accent-blue: rgb(130 206 255 / 0.92);
        --lumos-accent-blue-soft: rgb(var(--lumos-land-teal) / 0.34);
        --lumos-accent-blue-bright: #a8e9ff;
        --lumos-accent-gold: #c6a66a;

        --lumos-vizyon-card-bg: rgba(4, 8, 18, 0.96);
        --lumos-vizyon-card-border: rgb(var(--lumos-land-teal) / 0.2);
        --lumos-vizyon-card-border-gold: rgb(var(--lumos-land-warm) / 0.16);
        --lumos-vizyon-eyebrow: rgb(152 174 200 / 0.78);
      }
      html {
        scroll-behavior: smooth;
      }
      body.lumos-landing {
        margin: 0;
        min-height: 100vh;
        background-color: var(--lumos-land-page);
        background-image:
          radial-gradient(ellipse 130% 88% at 50% -6%, rgb(12 40 88 / 0.48), transparent 54%),
          radial-gradient(ellipse 88% 52% at 94% 38%, rgb(var(--lumos-land-teal) / 0.06), transparent 46%),
          radial-gradient(ellipse 72% 48% at 10% 72%, rgb(var(--lumos-land-warm) / 0.028), transparent 50%),
          linear-gradient(178deg, #010308 0%, #061022 44%, #030714 100%);
        background-attachment: fixed;
        color: var(--lumos-land-title);
        font-family: ui-sans-serif, system-ui, "Segoe UI", Roboto, sans-serif;
        line-height: 1.6;
      }
      .lumos-site-nav {
        margin: 0 0 clamp(0.65rem, 1.8vw, 1rem);
        padding-bottom: clamp(0.5rem, 1.3vw, 0.72rem);
        border-bottom: 1px solid rgb(var(--lumos-land-teal) / 0.38);
        box-shadow: 0 1px 0 rgb(var(--lumos-land-warm-deep) / 0.14);
      }
      .lumos-site-nav__bar {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 0.45rem 0.65rem;
        flex-wrap: wrap;
      }
      .lumos-site-nav__brand-left {
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        margin-right: auto;
        padding-left: 0.05rem;
        overflow: visible;
        align-self: flex-start;
        padding-top: 0.12rem;
      }
      .lumos-site-nav__corner {
        flex: 0 0 auto;
        padding-left: 0.35rem;
        padding-right: max(0.15rem, env(safe-area-inset-right, 0px));
      }
      .lumos-site-nav__list {
        display: flex;
        flex-wrap: nowrap;
        align-items: center;
        flex: 1 1 auto;
        min-width: 0;
        gap: 0.25rem 0.65rem;
        margin: 0;
        padding: 0 0 2px;
        list-style: none;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: thin;
        scrollbar-color: rgb(var(--lumos-land-teal) / 0.38) transparent;
      }
      .lumos-site-nav__list::-webkit-scrollbar {
        height: 4px;
      }
      .lumos-site-nav__list::-webkit-scrollbar-thumb {
        background: rgb(var(--lumos-land-teal) / 0.4);
        border-radius: 4px;
      }
      .lumos-site-nav__link {
        display: inline-block;
        flex-shrink: 0;
        padding: 0.32rem 0.48rem;
        font-size: clamp(0.7rem, 2.35vw, 0.85rem);
        font-weight: 600;
        letter-spacing: 0.02em;
        color: rgb(var(--lumos-land-teal) / 0.88);
        text-decoration: none;
        white-space: nowrap;
        border-radius: 8px;
        border: 1px solid transparent;
        transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
      }
      .lumos-site-nav__link:hover,
      .lumos-site-nav__link:focus-visible {
        color: var(--lumos-accent-blue-bright);
        border-color: rgb(var(--lumos-land-teal) / 0.38);
        background: rgba(8, 14, 28, 0.58);
      }
      .lumos-site-nav__link:focus-visible {
        outline: 2px solid rgb(var(--lumos-land-teal) / 0.45);
        outline-offset: 2px;
      }
      .lumos-site-nav__link--accent {
        color: rgb(var(--lumos-land-warm) / 0.88);
      }
      .lumos-site-nav__link--accent:hover,
      .lumos-site-nav__link--accent:focus-visible {
        color: rgb(var(--lumos-land-warm) / 0.98);
        border-color: rgb(var(--lumos-land-warm-deep) / 0.38);
        background: rgba(12, 10, 8, 0.5);
      }
      .lumos-site-nav__brand-left .lumos-site-nav__logo {
        margin-right: 0;
      }
      .lumos-site-nav__logo {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 44px;
        min-height: 44px;
        padding: 0.28rem 0.32rem;
        overflow: visible;
        border-radius: 999px;
        border: 1px solid transparent;
        text-decoration: none;
        transition: border-color 0.2s ease, background 0.2s ease;
      }
      .lumos-site-nav__logo:hover,
      .lumos-site-nav__logo:focus-visible {
        border-color: rgb(var(--lumos-land-teal) / 0.22);
        background: rgba(8, 14, 28, 0.28);
      }
      .lumos-site-nav__logo:focus-visible {
        outline: 2px solid rgb(var(--lumos-land-teal) / 0.45);
        outline-offset: 2px;
      }
      /** Lumos site logosu: vektör ağaç işareti (lumos-tree-logo.svg); filtre bağlamda (nav / hero) ayrı */
      .lumos-logo-mark {
        display: block;
        box-sizing: border-box;
        flex-shrink: 0;
        object-fit: contain;
        object-position: center center;
      }
      .lumos-site-nav__logo .lumos-logo-mark {
        width: 1.42rem;
        height: 1.42rem;
        max-width: none;
        max-height: none;
        opacity: 1;
        filter: brightness(1.06) saturate(1.08) contrast(1.04)
          drop-shadow(0 0 1px rgb(56 206 255 / 0.22))
          drop-shadow(0 0 10px rgb(56 206 255 / 0.08))
          drop-shadow(0 0 18px rgb(56 206 255 / 0.04));
      }
      .lumos-hero-title-lockup {
        display: flex;
        align-items: center;
        gap: clamp(0.28rem, 1vw, 0.48rem);
        margin: 0 0 0.45rem;
        overflow: visible;
        min-width: 0;
      }
      .lumos-hero-title-lockup .lumos-hero-title-mark {
        width: clamp(1.36rem, 3.4vw, 1.82rem);
        height: clamp(1.36rem, 3.4vw, 1.82rem);
        margin-top: 0.04em;
        margin-right: 0;
        flex-shrink: 0;
        max-width: 100%;
        box-sizing: border-box;
        border-radius: 0;
        background: none;
        opacity: 1;
        filter: brightness(1.07) saturate(1.1) contrast(1.04)
          drop-shadow(0 0 1px rgb(var(--lumos-land-teal) / 0.28))
          drop-shadow(0 0 12px rgb(var(--lumos-land-teal) / 0.1))
          drop-shadow(0 0 22px rgb(var(--lumos-land-teal) / 0.05));
        box-shadow: none;
      }
      .lumos-hero-title-lockup .lumos-hero-title-page {
        margin: 0;
      }
      .lumos-hero-actions {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 0.55rem;
        margin: 0.35rem 0 0;
      }
      /** Lumos'a sor: hero altında tam genişlik ince şerit — hero metin/sahne sıkışması yok */
      .lumos-hero-ask-band {
        box-sizing: border-box;
        width: 100%;
        max-width: min(44rem, 100%);
        margin: clamp(0.85rem, 2.2vw, 1.35rem) auto 0;
        padding: 0;
      }
      .lumos-hero-ask {
        display: flex;
        flex-wrap: nowrap;
        align-items: stretch;
        gap: 0.45rem 0.55rem;
        margin: 0;
        max-width: 100%;
        min-width: 0;
      }
      .lumos-hero-ask__field {
        flex: 1 1 12rem;
        min-width: 0;
        box-sizing: border-box;
        padding: 0.38rem 0.55rem;
        border-radius: 8px;
        border: 1px solid rgb(var(--lumos-land-teal) / 0.42);
        background: rgba(4, 10, 22, 0.88);
        color: var(--lumos-text-body);
        font-size: clamp(0.8rem, 1.85vw, 0.9rem);
        line-height: 1.35;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;
      }
      .lumos-hero-ask__field::placeholder {
        color: rgb(174 182 200 / 0.55);
      }
      .lumos-hero-ask__field:hover {
        border-color: rgb(var(--lumos-land-teal) / 0.58);
        box-shadow: 0 0 0 1px rgb(var(--lumos-land-warm-deep) / 0.12);
      }
      .lumos-hero-ask__field:focus {
        outline: none;
        border-color: rgb(var(--lumos-land-warm) / 0.45);
        box-shadow: 0 0 0 1px rgb(var(--lumos-land-warm) / 0.22), 0 0 0 3px rgb(var(--lumos-land-teal) / 0.12);
        color: var(--lumos-land-title);
      }
      .lumos-hero-ask__field:focus-visible {
        outline: 2px solid rgb(var(--lumos-land-warm) / 0.42);
        outline-offset: 2px;
      }
      .lumos-hero-ask__submit {
        flex: 0 0 auto;
        flex-shrink: 0;
        box-sizing: border-box;
        min-height: 40px;
        padding: 0.38rem 0.95rem;
        border-radius: 8px;
        border: 1px solid rgb(118 198 238 / 0.52);
        background: linear-gradient(
          152deg,
          rgb(26 108 168) 0%,
          rgb(12 72 132) 46%,
          rgb(7 48 102) 100%
        );
        color: #f2f7fb;
        text-shadow: 0 1px 0 rgb(0 0 0 / 0.22);
        font-size: clamp(0.78rem, 1.75vw, 0.88rem);
        font-weight: 700;
        letter-spacing: 0.06em;
        white-space: nowrap;
        cursor: pointer;
        box-shadow:
          inset 0 1px 0 rgb(255 255 255 / 0.14),
          0 2px 10px rgb(0 0 0 / 0.32);
        transition: border-color 0.2s ease, box-shadow 0.2s ease, color 0.2s ease, background 0.2s ease;
      }
      .lumos-hero-ask__submit:hover {
        border-color: rgb(168 220 248 / 0.78);
        color: #ffffff;
        box-shadow:
          inset 0 1px 0 rgb(255 255 255 / 0.18),
          0 0 0 1px rgb(var(--lumos-land-teal) / 0.32),
          0 0 20px rgb(var(--lumos-land-teal) / 0.26),
          0 0 32px rgb(var(--lumos-land-warm) / 0.14),
          0 4px 14px rgb(0 0 0 / 0.38);
      }
      .lumos-hero-ask__submit:focus-visible {
        outline: 2px solid rgb(var(--lumos-land-warm) / 0.48);
        outline-offset: 2px;
        border-color: rgb(188 228 255 / 0.88);
        color: #ffffff;
        box-shadow:
          inset 0 1px 0 rgb(255 255 255 / 0.2),
          0 0 0 1px rgb(var(--lumos-land-teal) / 0.42),
          0 0 22px rgb(var(--lumos-land-teal) / 0.34),
          0 0 40px rgb(var(--lumos-land-warm) / 0.2),
          0 4px 16px rgb(0 0 0 / 0.4);
      }
      .lumos-hero-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-sizing: border-box;
        min-height: 44px;
        padding: 0.52rem 1.05rem;
        border-radius: 10px;
        font-size: clamp(0.84rem, 2vw, 0.92rem);
        font-weight: 600;
        letter-spacing: 0.02em;
        text-decoration: none;
        white-space: nowrap;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, color 0.2s ease, transform 0.2s ease;
      }
      .lumos-hero-btn--primary {
        border: 1px solid rgb(var(--lumos-land-teal) / 0.48);
        background: linear-gradient(165deg, rgba(18, 28, 42, 0.95) 0%, rgba(14, 18, 30, 0.92) 100%);
        color: var(--lumos-interactive-fg);
      }
      .lumos-hero-btn--primary:hover,
      .lumos-hero-btn--primary:focus-visible {
        border-color: rgb(var(--lumos-land-teal) / 0.68);
        color: var(--lumos-interactive-fg-hover);
        box-shadow: 0 6px 22px rgba(0, 0, 0, 0.35), 0 0 0 1px rgb(var(--lumos-land-teal) / 0.12);
        transform: translateY(-1px);
      }
      .lumos-hero-btn--ghost {
        border: 1px solid rgb(var(--lumos-land-teal) / 0.32);
        background: rgba(8, 14, 26, 0.62);
        color: rgb(var(--lumos-land-teal) / 0.88);
      }
      .lumos-hero-btn--ghost:hover,
      .lumos-hero-btn--ghost:focus-visible {
        border-color: rgb(var(--lumos-land-teal) / 0.52);
        color: var(--lumos-interactive-fg-hover);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.28), 0 0 0 1px rgb(var(--lumos-land-warm-deep) / 0.12);
        transform: translateY(-1px);
      }
      .lumos-hero-btn:focus-visible {
        outline: 2px solid rgb(var(--lumos-land-teal) / 0.5);
        outline-offset: 3px;
      }
      #ilkeler.lumos-section--post-hero {
        margin-top: clamp(0.25rem, 1vw, 0.5rem);
      }
      #moduller,
      #ilkeler,
      #dunya,
      #dunya-vizyon,
      #gelistirici,
      #kurulum,
      #neden-lumos {
        scroll-margin-top: 1.25rem;
      }
      /** Giriş: sinematik şerit — metin solda, sağda Atatürk sınıf sahnesi (kırpılmış raster, mockup UI yok) */
      #top.lumos-section {
        position: relative;
        isolation: isolate;
        margin: 0;
        width: 100%;
        max-width: 100%;
        padding-left: 0;
        padding-right: 0;
        padding-bottom: clamp(1.35rem, 3.2vw, 2.15rem);
        overflow: visible;
        min-height: 0;
        border-radius: 0;
        background: radial-gradient(ellipse 120% 80% at 18% 20%, rgb(12 40 88 / 0.35), transparent 55%), #020511;
      }
      #top.lumos-section--tight-top {
        padding-top: 0;
      }
      .lumos-site-nav--sticky {
        position: sticky;
        top: 0;
        z-index: 24;
        margin: 0 calc(-1 * clamp(0.65rem, 2vw, 1.25rem));
        padding: clamp(0.35rem, 1vw, 0.55rem) clamp(0.65rem, 2vw, 1.25rem) clamp(0.45rem, 1.1vw, 0.65rem);
        background: rgb(2 5 17 / 0.82);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom: 1px solid rgb(var(--lumos-land-teal) / 0.28);
      }
      .lumos-site-nav__brand {
        display: inline-flex;
        align-items: center;
        gap: 0.42rem;
        text-decoration: none;
        color: inherit;
      }
      .lumos-site-nav__brand-text {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.08rem;
        line-height: 1.05;
      }
      .lumos-site-nav__brand-title {
        font-size: clamp(0.82rem, 2.1vw, 0.98rem);
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--lumos-land-title);
      }
      .lumos-site-nav__brand-sub {
        font-size: clamp(0.58rem, 1.35vw, 0.68rem);
        font-weight: 650;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgb(var(--lumos-land-warm) / 0.9);
      }
      .lumos-hero-cinematic__inner {
        position: relative;
        z-index: 2;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        padding-top: clamp(0.35rem, 1vw, 0.55rem);
        padding-bottom: clamp(1.1rem, 2.8vw, 1.75rem);
      }
      /** Tek hero şeridi: metin + sahne aynı ızgarada; sahne ayrı “kart” gibi görünmesin */
      .lumos-hero-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: clamp(0.75rem, 2vw, 1.25rem);
        align-items: center;
        width: 100%;
        min-height: 0;
        padding-top: clamp(0.35rem, 1.2vw, 0.75rem);
      }
      @media (min-width: 768px) {
        .lumos-hero-layout {
          grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.95fr);
          gap: clamp(0.85rem, 2.2vw, 1.65rem);
          align-items: stretch;
        }
        .lumos-hero-actions {
          flex-direction: row;
          flex-wrap: nowrap;
          align-items: center;
          justify-content: flex-start;
          gap: 0.55rem 0.75rem;
        }
        .lumos-hero-btn {
          width: auto;
          flex: 0 0 auto;
        }
      }
      .lumos-hero-scene {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        box-sizing: border-box;
        min-width: 0;
        padding: clamp(0.12rem, 0.45vw, 0.35rem);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgb(var(--lumos-land-teal) / 0.14);
        background-color: #020511;
        background-image:
          radial-gradient(ellipse 95% 72% at 82% 22%, rgb(56 206 255 / 0.12), transparent 58%),
          radial-gradient(ellipse 70% 55% at 18% 78%, rgb(56 206 255 / 0.05), transparent 52%),
          radial-gradient(ellipse 50% 42% at 48% 48%, rgb(255 255 255 / 0.03), transparent 55%),
          radial-gradient(ellipse 58% 50% at 12% 92%, rgb(var(--lumos-land-warm) / 0.05), transparent 54%),
          linear-gradient(168deg, #020511 0%, #061022 55%, #01040d 100%);
        background-repeat: no-repeat, no-repeat, no-repeat, no-repeat, no-repeat;
        box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.04);
        min-height: clamp(260px, 46vmin, 620px);
      }
      .lumos-hero-scene__img {
        position: relative;
        z-index: 2;
        display: block;
        box-sizing: border-box;
        width: 100%;
        max-width: 100%;
        height: auto;
        max-height: clamp(240px, min(56vmin, 68vh), 640px);
        object-fit: contain;
        object-position: center center;
        margin-inline: auto;
        pointer-events: none;
        user-select: none;
      }
      .lumos-hero-scene::before {
        content: "";
        position: absolute;
        inset: -35% -20%;
        z-index: 0;
        pointer-events: none;
        opacity: 0.35;
        background: radial-gradient(ellipse 55% 90% at 88% 32%, rgb(160 210 255 / 0.14), transparent 62%);
      }
      .lumos-hero-scene::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background:
          linear-gradient(198deg, rgb(1 3 10 / 0.22) 0%, rgb(1 3 10 / 0.05) 44%, transparent 62%),
          radial-gradient(ellipse 72% 58% at 90% 24%, rgb(56 206 255 / 0.04), transparent 58%),
          linear-gradient(160deg, rgb(2 5 17 / 0.18) 0%, transparent 52%);
      }
      @media (max-width: 767.98px) {
        .lumos-hero-scene {
          min-height: clamp(200px, 48vw, 380px);
        }
        .lumos-hero-scene__img {
          max-height: clamp(200px, min(56vw, 50vh), 420px);
        }
      }
      /** Masaüstü: sahne sütunu metin yüksekliğine gerilmesin; görsel daha büyük, dikey lacivert şerit azalsın */
      @media (min-width: 768px) {
        .lumos-hero-scene {
          align-self: start;
          padding: clamp(0.08rem, 0.35vw, 0.22rem) clamp(0.18rem, 0.55vw, 0.38rem);
          min-height: clamp(280px, 42vmin, 560px);
        }
        .lumos-hero-scene__img {
          max-height: clamp(300px, min(64vmin, 80vh), 720px);
        }
      }
      .lumos-hero-copy {
        max-width: min(38rem, 100%);
        flex: 0 1 auto;
        min-width: 0;
      }
      .lumos-hero-eyebrow {
        margin: 0 0 0.55rem;
